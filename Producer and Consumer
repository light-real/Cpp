#include<iostream>
#include<string>
#include<mutex>
#include<queue>
#include<condition_variable>

std::queue<int> que; //定义一个队列
std::condition_variable cv;
std::mutex mtx;

void Producer() {  //定义生产者
	for (int i = 0; i < 10; i++) {
		{
			std::unique_lock<std::mutex> ul(mtx); //加锁
			que.push(i); //往队列中加任务
			//通知消费者 队列中已经有任务
			cv.notify_one();
			std::cout << "Producer : " << i << std::endl;
		}

		std::this_thread::sleep_for(std::chrono::microseconds(100)); //睡眠一会
	}
}

void Consumer() {
	while (1) {
		std::unique_lock<std::mutex> ul(mtx); 
		//condition_variable.wait()的使用方法 第一个参数是一个锁 第二个参数是一个bool值 如果为true向下执行 否则等待
		//condition_variable.wait() 一直处于阻塞状态 直到另一个线程用notify_one()或者用notify_all去通知它
		cv.wait(ul, []() {
			return !que.empty();
			});  //如果队列为空 则一直等待
		int front = que.front();
		que.pop();
		std::cout << "Consumer : " << front << std::endl;
	}
}

int main() {
	std::thread t1(Producer);
	std::thread t2(Consumer);

	t1.join();
	t2.join();

	return 0;
}
