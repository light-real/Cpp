#include<iostream>
#include<mutex>
#include<thread>
#include<queue>
#include<vector>
#include<string>
#include<condition_variable>
#include<functional>

std::mutex m;

class ThreadPool {
public:
	ThreadPool(int numThreads) :stop(false) {  //构造函数
		for (int i = 0; i < numThreads; i++) {
			threads.emplace_back([this] {
				while (1) {
					std::unique_lock<std::mutex> lock(mtx); //加锁
					condition.wait(lock, [this] {
						return !tasks.empty() || stop;
						});

					if (stop && tasks.empty()) {  //如果线程池已经暂停并且线程池为空 直接返回
						return;
					}

					std::function<void()> task(std::move(tasks.front()));
					tasks.pop();
					lock.unlock();
					task();
				}
				});
		}
	}

	ThreadPool(const ThreadPool& tp) = delete;  //禁用拷贝构造
	ThreadPool& operator=(const ThreadPool& tp) = delete; //禁用赋值运算符
	

	~ThreadPool() {
		{
			std::unique_lock<std::mutex> lock(mtx);  //对于共享变量的访问 需要加锁 unique_lock作用域结束以后直接解锁
			stop = true;
		}
		condition.notify_all();  //通知所有线程将队列中的任务都取完
		for (auto& t : threads) {
			t.join();
		}
	}

	template<class F,class...Args>
	void enqueue(F &&f,Args&&...args) {  //两个取地址符是右值引用 在函数模板里面 右值引用是万能引用
		std::function<void()> task = 
			std::bind(std::forward<F>(f), std::forward<Args>(args)...);
		{
			std::unique_lock<std::mutex> lock(mtx);
			tasks.emplace(std::move(task));
		}
		condition.notify_one();
	}

private:
	std::vector<std::thread> threads;  //线程数组
	std::queue<std::function<void()>> tasks;  //任务队列 每一个任务都是函数
	std::mutex mtx;
	std::condition_variable condition;  //条件变量
	bool stop;  //线程是否暂停
};

int main() {
	ThreadPool pool(4);
	
	for (int i = 0; i < 10; i++) {
		pool.enqueue([i] {
			{
				std::unique_lock<std::mutex> lock(m);
				std::cout << "task : " << i << "is running" << std::endl;
			}
			
			std::this_thread::sleep_for(std::chrono::seconds(1));
			{
				std::unique_lock<std::mutex> lock(m);
				std::cout << "task : " << i << "is over" << std::endl;
			}
			
			});
	}
	return 0;
}
